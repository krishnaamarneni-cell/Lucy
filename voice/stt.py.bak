import groq
import os
import time
import tempfile
import collections
import sounddevice as sd
import numpy as np
import scipy.io.wavfile as wav
import webrtcvad
from dotenv import load_dotenv
import voice.state as state

load_dotenv()
client = groq.Groq(api_key=os.getenv("GROQ_API_KEY"))

SAMPLE_RATE = 16000
FRAME_MS = 30                    # VAD works on 10/20/30 ms frames
FRAME_SAMPLES = int(SAMPLE_RATE * FRAME_MS / 1000)
VAD_AGGRESSIVENESS = 2           # 0 = permissive, 3 = very strict. 2 is the sweet spot.
MAX_RECORD_SECONDS = 10          # hard cap on recording length
SILENCE_TAIL_MS = 800            # stop after this much trailing silence
START_TIMEOUT_SECONDS = 4        # how long to wait for speech to start
MIN_SPEECH_MS = 300              # ignore recordings shorter than this (noise clicks)

JUNK = {".", "see", "see.", "hello.", "bye", "thanks", "thank you",
        "you", "be", "the", "sí", "si", "el", "them", "a", "i", "oh", "uh",
        "goodbye", "yeah", "hmm", "mm", "ah"}


def _record_until_silence():
    """Record audio, start when speech begins, stop after a pause."""
    vad = webrtcvad.Vad(VAD_AGGRESSIVENESS)
    ring = collections.deque(maxlen=int(SILENCE_TAIL_MS / FRAME_MS))
    voiced_frames = []
    triggered = False
    start_time = time.time()

    with sd.InputStream(samplerate=SAMPLE_RATE, channels=1, dtype='int16',
                        blocksize=FRAME_SAMPLES) as stream:
        while True:
            elapsed = time.time() - start_time
            if elapsed > MAX_RECORD_SECONDS:
                break
            if not triggered and elapsed > START_TIMEOUT_SECONDS:
                return None  # no speech detected at all

            frame, _ = stream.read(FRAME_SAMPLES)
            frame_bytes = frame.tobytes()
            is_speech = vad.is_speech(frame_bytes, SAMPLE_RATE)

            if not triggered:
                ring.append((frame, is_speech))
                num_voiced = sum(1 for _, s in ring if s)
                if num_voiced > 0.5 * ring.maxlen:
                    triggered = True
                    voiced_frames.extend(f for f, _ in ring)
                    ring.clear()
            else:
                voiced_frames.append(frame)
                ring.append((frame, is_speech))
                num_unvoiced = sum(1 for _, s in ring if not s)
                if num_unvoiced > 0.9 * ring.maxlen:
                    break

    if not voiced_frames:
        return None

    duration_ms = len(voiced_frames) * FRAME_MS
    if duration_ms < MIN_SPEECH_MS:
        return None

    return np.concatenate(voiced_frames, axis=0)


def listen(timeout=None):
    """Record speech using VAD, then transcribe with Whisper."""
    while state.is_speaking:
        time.sleep(0.1)

    print("🎙️ Listening...")
    try:
        audio = _record_until_silence()
        if audio is None:
            return None

        with tempfile.NamedTemporaryFile(delete=False, suffix=".wav") as f:
            wav.write(f.name, SAMPLE_RATE, audio)
            tmp_path = f.name

        with open(tmp_path, "rb") as f:
            result = client.audio.transcriptions.create(
                model="whisper-large-v3-turbo",
                file=f,
                response_format="verbose_json",
                language="en"
            )
        os.remove(tmp_path)

        # verbose_json gives us no_speech_prob — use it to reject hallucinations
        text = result.text.strip() if hasattr(result, "text") else str(result).strip()

        # Check Whisper's own confidence (available in verbose_json mode)
        segments = getattr(result, "segments", []) or []
        if segments:
            avg_no_speech = sum(s.get("no_speech_prob", 0) for s in segments) / len(segments)
            if avg_no_speech > 0.6:
                return None  # Whisper itself thinks this isn't speech

        clean = text.lower().strip(".!?,")
        if len(clean) < 3 or clean in JUNK:
            return None

        # Strip leading wake word if it leaked into the transcript
        for wake in ("alexa", "alexa,", "hey alexa", "hey alexa,"):
            if clean.startswith(wake):
                text = text[len(wake):].strip(" ,.")
                break

        if len(text.strip()) < 2:
            return None

        return text
    except Exception as e:
        print(f"STT error: {e}")
        return None
